      <column caption='Total Spending' datatype='integer' name='[Calculation_0953890304659456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[MntFishProducts] + [MntFruits] + [MntGoldProds] + [MntMeatProducts] + [MntSweetProducts] + [MntWines]' />
      </column>
      <column caption='Purchase Frequency' datatype='integer' name='[Calculation_0953890305163265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[NumCatalogPurchases] + [NumDealsPurchases] + [NumStorePurchases] + [NumWebPurchases]' />
      </column>
      <column caption='Campaign Acc Rate' datatype='real' name='[Calculation_0953890305839106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([AcceptedCmp1] + [AcceptedCmp2] + [AcceptedCmp3] + [AcceptedCmp4] + [AcceptedCmp5] + [Response]) &#13;&#10;/ &#13;&#10;COUNTD([ID])' />
      </column>
      <column caption='Age Grouping' datatype='string' name='[Calculation_0953890314088454]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &gt;= 20 AND [Age] &lt;= 35 THEN &quot;Young Adult&quot;&#13;&#10;ELSEIF [Age] &gt;= 36 AND [Age] &lt;= 60 THEN &quot;Adult&quot;&#13;&#10;ELSE &quot;Elderly&quot; END' />
      </column>
